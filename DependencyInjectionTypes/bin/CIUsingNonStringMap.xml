<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN 2.0//EN"
			"http://www.springframework.org/dtd/spring-beans-2.0.dtd">

<beans>
	<bean id="q" class="com.taranga.dependentObject.QuestionMap">
		<constructor-arg value="1" type="int"></constructor-arg>
		<constructor-arg value="Advantages of Spring framework"></constructor-arg>
		<constructor-arg>
		<map>
			<entry  key-ref="a1" value-ref="u1" />
			<entry  key-ref="a2" value-ref="u2" />
		</map>
		</constructor-arg>
		</bean>
		
		<bean id="a1" class="com.taranga.dependentObject.AnswerMap">
		<constructor-arg value="1" type="int"></constructor-arg>
		<constructor-arg value="Predefined template"></constructor-arg>
		<constructor-arg value="1/1/19"></constructor-arg>
		</bean>
		
		<bean id="a2" class="com.taranga.dependentObject.AnswerMap">
		<constructor-arg value="2" type="int"></constructor-arg>
		<constructor-arg value="Loose coupling"></constructor-arg>
		<constructor-arg value="2/1/19"></constructor-arg>
		</bean>
		
		<bean id="u1" class="com.taranga.dependentObject.UserMap">
		<constructor-arg value="10" type="int"></constructor-arg>
		<constructor-arg value="Rukhaya"></constructor-arg>
		<constructor-arg value="rukhaya@gmail.com"></constructor-arg>
		</bean>
		
		<bean id="u2" class="com.taranga.dependentObject.UserMap">
		<constructor-arg value="11" type="int"></constructor-arg>
		<constructor-arg value="sahana"></constructor-arg>
		<constructor-arg value="sahana@gmail.com"></constructor-arg>
		</bean>
	
</beans>